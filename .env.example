# ============================================================
# Environment Configuration
# Copy to .env and fill in your values
# ============================================================
# cp .env.example .env

# --- Google Cloud / Vertex AI ---
# Set via: gcloud auth application-default login
# Or supply a service account key path:
GOOGLE_APPLICATION_CREDENTIALS=         # /path/to/sa-key.json (leave blank for ADC)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1

# Gemini model selection
# gemini-1.5-pro  → highest capability (Agent Platform production)
# gemini-1.5-flash → faster, lower cost (dev / high-throughput)
GEMINI_MODEL=gemini-1.5-pro
EMBEDDING_MODEL=text-embedding-004

# --- AlloyDB Local Replica (Docker) ---
ALLOYDB_HOST=localhost
ALLOYDB_PORT=5432
ALLOYDB_USER=alloydb_admin
ALLOYDB_PASSWORD=alloydb_local_secret
ALLOYDB_DATABASE=vertex_rag_db

# Connection pool settings
ALLOYDB_POOL_SIZE=10
ALLOYDB_MAX_OVERFLOW=20
ALLOYDB_POOL_TIMEOUT=30

# --- FastAPI / Agent Platform Endpoint ---
API_HOST=0.0.0.0
API_PORT=8080
API_RELOAD=true
LOG_LEVEL=info

# --- pgAdmin (AlloyDB Studio) ---
PGADMIN_EMAIL=admin@vertex-rag.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
